APP_NAME="API Facturación SUNAT - BETA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=https://app.nextfood.pe,http://localhost:5173,http://127.0.0.1:5173

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_PE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=db_api_sunat
DB_USERNAME=root
DB_PASSWORD=
# En produccion con Supabase, usar el host/puerto/usuario de Supavisor en modo
# transaccional. Usar el endpoint directo solo para migraciones que lo exijan.
DB_SSLMODE=prefer

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Worker independiente de comprobantes SUNAT
SUNAT_WORKER_ENABLED=true
SUNAT_WORKER_QUEUE=sunat
SUNAT_WORKER_BATCH_SIZE=10
SUNAT_WORKER_LEASE_SECONDS=300
SUNAT_WORKER_STALE_PROCESSING_SECONDS=300
SUNAT_WORKER_MAX_ATTEMPTS=10
SUNAT_WORKER_BACKOFF_SECONDS=60,180,600,1800,3600,10800
SUNAT_WORKER_ALERT_QUEUE_DEPTH=100
SUNAT_WORKER_ALERT_OLDEST_MINUTES=15

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Sanctum Configuration para desarrollo  
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8000,127.0.0.1,127.0.0.1:8000
SANCTUM_EXPIRATION=1440
SANCTUM_TOKEN_PREFIX=sunat_beta_
SANCTUM_VERIFY_IP=false
SANCTUM_LOG_USAGE=true
SANCTUM_MAX_INACTIVITY=120
SANCTUM_MAX_TOKENS=10
SANCTUM_ROTATE_TOKENS=false
SANCTUM_PURGE_DAYS=7

# SUNAT Configuration - BETA Environment
SUNAT_ENVIRONMENT=beta
SUNAT_CERTIFICATE_PATH=
SUNAT_CERTIFICATE_PASSWORD=
SUNAT_PRIVATE_KEY_PATH=
SUNAT_INTERNAL_API_KEY=

# Supabase Auth validation for protected SUNAT endpoints
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Files Configuration
FILES_STORAGE_PATH=storage/app/sunat
FILES_MAX_SIZE=10240

VITE_APP_NAME="${APP_NAME}"
